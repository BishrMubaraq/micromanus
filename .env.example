# Canonical site URL (required in production — used for OAuth + checkout redirects)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase project
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
# Either anon key or publishable key works
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AES-256-GCM key for encrypting BYOK provider API keys (64 hex chars)
# Generated automatically by `npm run setup` if left blank
# openssl rand -hex 32
PROVIDER_ENCRYPTION_KEY=

# SerpAPI (server-side web search for the research agent)
SERPAPI_API_KEY=

# Lemon Squeezy billing (optional for local coupon-only testing)
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_VARIANT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# ---------------------------------------------------------------------------
# Auth setup (Supabase Dashboard)
# 1. Authentication → Providers → enable GitHub
# 2. GitHub OAuth App callback URL: {NEXT_PUBLIC_APP_URL}/auth/callback
# 3. Site URL: {NEXT_PUBLIC_APP_URL}
#
# Billing webhook (Lemon Squeezy)
# URL: {NEXT_PUBLIC_APP_URL}/api/webhooks/lemon-squeezy
# Signing secret → LEMON_SQUEEZY_WEBHOOK_SECRET
# ---------------------------------------------------------------------------
