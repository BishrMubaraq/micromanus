NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# AES-256 key for encrypting user provider API keys (64 hex chars)
# openssl rand -hex 32
PROVIDER_ENCRYPTION_KEY=

# Brave Search (server-side tool)
BRAVE_API_KEY=

# Lemon Squeezy billing
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_VARIANT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Interim testing: enable Email provider in Supabase Auth.
# For faster local signup, disable "Confirm email" under Auth → Providers → Email.
